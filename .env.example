# ============================================================
# HarvestFile Environment Variables
# Copy this to .env.local and fill in your values
# ============================================================

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ──
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Create a webhook endpoint at https://dashboard.stripe.com/webhooks
# pointing to https://yourdomain.com/api/stripe/webhook
# Events to listen for:
#   - checkout.session.completed
#   - customer.subscription.updated
#   - customer.subscription.deleted
#   - invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# Create a Product + Price in Stripe Dashboard:
# Product: "HarvestFile Pro"
# Price: $29/month recurring
# Copy the price ID (starts with price_)
STRIPE_PRO_MONTHLY_PRICE_ID=price_...

# Optional: annual price at $278/year (20% discount)
STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# ── Anthropic (for AI reports) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── NASS (USDA crop data) ──
NASS_API_KEY=your-nass-key
